{
  "name": "standup-report",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "standup": "src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile standup",
    "build:linux": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile dist/standup-linux",
    "build:windows": "bun build src/index.ts --compile --target=bun-windows-x64 --outfile dist/standup.exe",
    "build:macos": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile dist/standup-macos"
  },
  "devDependencies": {
    "bun-types": "^1.3.11"
  }
}
